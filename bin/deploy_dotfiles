#!/bin/bash

ensure_file_contains '~/dotfiles/gitconfig' \
                    '[include]\n\tpath = ~/dotfiles/gitconfig' \
                    $HOME/.gitconfig

ensure_file_contains "set -g mouse off" $HOME/.tmux.conf

# Claude Code settings
if command -v claude &>/dev/null; then
    mkdir -p "$HOME/.claude"
    cp "$HOME/dotfiles/claude_settings.json" "$HOME/.claude/settings.json"
fi

# Shared agent rules + skills, linked into every agent so they stay in sync
AGENTS_SRC="$HOME/dotfiles/AGENTS.md"
SKILLS_SRC="$HOME/dotfiles/skills"

# Symlink every skill dir under $SKILLS_SRC into the given target skills dir
link_skills() {
    mkdir -p "$1"
    for skill in "$SKILLS_SRC"/*/; do
        [ -d "$skill" ] || continue
        ln -sfn "${skill%/}" "$1/$(basename "$skill")"
    done
}

# Claude Code: global memory + skills
if command -v claude &>/dev/null; then
    ln -sfn "$AGENTS_SRC" "$HOME/.claude/CLAUDE.md"
    link_skills "$HOME/.claude/skills"
fi

# Codex: global AGENTS.md + skills
if command -v codex &>/dev/null; then
    link_skills "$HOME/.codex/skills"
    ln -sfn "$AGENTS_SRC" "$HOME/.codex/AGENTS.md"
fi

# Cursor: per-project AGENTS.md is the reliable path; ~/.cursor/AGENTS.md is best-effort
if [ -d "$HOME/.cursor" ]; then
    ln -sfn "$AGENTS_SRC" "$HOME/.cursor/AGENTS.md"
    if [ -d "$HOME/.cursor/skills-cursor" ]; then
        link_skills "$HOME/.cursor/skills-cursor"
    fi
fi

if [ -e "$HOME/.SpaceVim" ]; then
    rm -rf "$HOME/.SpaceVim.d"
    ln -s "$HOME/dotfiles/space_vim_config" "$HOME/.SpaceVim.d"
else
    rm -f "$HOME/.vimrc"
    ln -s "$HOME/dotfiles/vimrc" "$HOME/.vimrc"
fi
